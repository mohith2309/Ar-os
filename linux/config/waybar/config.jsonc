[
  {
    "name": "top",
    "layer": "top",
    "position": "top",
    "height": 46,
    "margin-top": 10,
    "margin-left": 14,
    "margin-right": 14,
    "modules-left": [
      "custom/launch",
      "custom/wclose",
      "custom/wmin",
      "custom/wmax"
    ],
    "modules-center": [
      "custom/ai"
    ],
    "modules-right": [
      "tray",
      "custom/net",
      "custom/bat",
      "clock",
      "custom/user",
      "custom/notif"
    ],
    "custom/launch": {
      "format": " ",
      "on-click": "~/.config/aros/launcher.sh",
      "tooltip": false
    },
    "custom/ai": {
      "format": "🔍    What do you want to do?              ▶",
      "on-click": "~/.config/aros/launcher.sh",
      "tooltip": false
    },
    "tray": {
      "icon-size": 16,
      "spacing": 8
    },
    "custom/net": {
      "format": "📶",
      "tooltip": false
    },
    "custom/bat": {
      "format": "🔋 100%",
      "tooltip": false
    },
    "clock": {
      "format": "{:%H:%M}",
      "tooltip-format": "{:%A %d %B}"
    },
    "custom/user": {
      "format": "👤",
      "tooltip": false
    },
    "custom/notif": {
      "exec": "~/.config/waybar/scripts/notif.sh",
      "return-type": "json",
      "interval": 2,
      "on-click": "makoctl dismiss -a",
      "on-click-right": "makoctl restore"
    },
    "custom/wclose": {
      "format": "●",
      "on-click": "hyprctl dispatch killactive",
      "tooltip": false
    },
    "custom/wmin": {
      "format": "●",
      "on-click": "hyprctl dispatch togglefloating",
      "tooltip": false
    },
    "custom/wmax": {
      "format": "●",
      "on-click": "hyprctl dispatch fullscreen 1",
      "tooltip": false
    }
  },
  {
    "name": "dock",
    "layer": "top",
    "position": "bottom",
    "height": 64,
    "margin-bottom": 12,
    "modules-center": [
      "custom/launcher",
      "custom/files",
      "custom/term",
      "custom/photos",
      "custom/music",
      "custom/notes",
      "custom/settings",
      "custom/about"
    ],
    "custom/launcher": {
      "format": " ",
      "on-click": "~/.config/aros/launcher.sh",
      "tooltip": false
    },
    "custom/files": {
      "exec": "~/.config/waybar/scripts/running.sh nautilus",
      "return-type": "json",
      "interval": 2,
      "on-click": "nautilus",
      "format": "{}",
      "tooltip": false
    },
    "custom/term": {
      "exec": "~/.config/waybar/scripts/running.sh kitty",
      "return-type": "json",
      "interval": 2,
      "on-click": "kitty",
      "format": "{}",
      "tooltip": false
    },
    "custom/photos": {
      "exec": "~/.config/waybar/scripts/running.sh loupe",
      "return-type": "json",
      "interval": 2,
      "on-click": "loupe || nautilus",
      "format": "{}",
      "tooltip": false
    },
    "custom/music": {
      "exec": "~/.config/waybar/scripts/running.sh texteditor",
      "return-type": "json",
      "interval": 2,
      "on-click": "gnome-text-editor",
      "format": "{}",
      "tooltip": false
    },
    "custom/notes": {
      "exec": "~/.config/waybar/scripts/running.sh texteditor",
      "return-type": "json",
      "interval": 2,
      "on-click": "gnome-text-editor",
      "format": "{}",
      "tooltip": false
    },
    "custom/settings": {
      "exec": "~/.config/waybar/scripts/running.sh control-center",
      "return-type": "json",
      "interval": 2,
      "on-click": "env XDG_CURRENT_DESKTOP=GNOME gnome-control-center",
      "format": "{}",
      "tooltip": false
    },
    "custom/about": {
      "exec": "~/.config/waybar/scripts/running.sh kitty",
      "return-type": "json",
      "interval": 2,
      "on-click": "kitty -e bash -c 'fastfetch||uname -a;read'",
      "format": "{}",
      "tooltip": false
    }
  }
]